{
  "private": true,
  "scripts": {
    "generate-placeholders": "tsx 'src/app/(main)/blog/scripts/generate-blur-placeholders.ts'",
    "typegen": "next typegen",
    "type-check": "yarn typegen && tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "build": "yarn generate-placeholders && yarn type-check && next build",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,css,scss}' && eslint --fix '**/*.{js,jsx,ts,tsx}'",
    "dev": "next dev",
    "postinstall": "yarn generate-placeholders || true"
  },
  "dependencies": {
    "@jaeungkim/gantt-chart": "^0.3.1",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.562.0",
    "motion": "^12.23.12",
    "next": "^16.1.7",
    "next-themes": "^0.4.6",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "tailwind-merge": "^3.4.0",
    "three": "0.182.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.16",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "0.182.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "plaiceholder": "^3.0.0",
    "postcss": "^8.5.4",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "yarn@4.9.1"
